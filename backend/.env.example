APP_NAME=Zellia API
SECRET_KEY=replace-with-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+psycopg://db_user:db_password@db_host:5432/db_name
REDIS_URL=redis://redis:6379/0

# Firebase Admin SDK service account JSON absolute path.
# Example (Windows): C:/secrets/firebase-service-account.json
# Example (Linux): /opt/secrets/firebase-service-account.json
FIREBASE_CREDENTIALS_PATH=
# Optional fallback when service account is not provided.
# Must match your Firebase project id, e.g. zellia-c629c
FIREBASE_PROJECT_ID=
# Alternative env name accepted by backend fallback logic.
GOOGLE_CLOUD_PROJECT=

# Cloudflare R2 — PRO family voice reminders (optional).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL for uploaded objects, e.g. https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=
